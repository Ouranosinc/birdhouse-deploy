    location /s3/${THREDDS_S3_BUCKET_NAME}/ {
        auth_request /secure-mount-thredds-to-s3-auth;
        auth_request_set $auth_status $upstream_status;
        proxy_pass http://s3:3000/${THREDDS_S3_BUCKET_NAME}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # s3:// clients often do not handle 301 redirects so requests to the thredds bucket without
    # a trailing slash will fail because nginx will send a redirect. 
    # With the following location block, nginx will instead handle it internally.
    location = /s3/${THREDDS_S3_BUCKET_NAME} {
        rewrite ^/s3/${THREDDS_S3_BUCKET_NAME}$ /s3/${THREDDS_S3_BUCKET_NAME}/ last;
    }

    # Deny access to listing (browsing) the catalog because we don't have a good way to check
    # whether they have browsing permissions for this resource.
    # This means that users must specifically request an exact path to the thredds file they want to access.
    # TODO: find a solution that allows us to check for browse permissions for a given prefix.
    location = /s3/${THREDDS_S3_BUCKET_NAME}/ {
        default_type text/plain;
        return 403 "Object listing operations not permitted for the ${THREDDS_S3_BUCKET_NAME} bucket.";
        deny all;
    }

    location = /secure-mount-thredds-to-s3-auth {
        internal;
        # Use the fileServer path to test whether the user has read permissions for the given resource
        proxy_pass ${BIRDHOUSE_PROXY_SCHEME}://${BIRDHOUSE_FQDN_PUBLIC}${TWITCHER_VERIFY_PATH}/thredds/fileServer/$request_uri_s3_thredds_path;
        proxy_pass_request_body off;
        proxy_set_header Host $host;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URI $request_uri;
        proxy_set_header X-Forwarded-Proto $real_scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host:$server_port;
    }
