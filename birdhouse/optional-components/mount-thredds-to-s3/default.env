export THREDDS_S3_BUCKET_NAME=thredds

# When waiting for the S3 service to be up: how long to sleep
# between attempts and how many attempts should the code make
# until giving up.
export THREDDS_S3_RETRY_ATTEMPTS=5
export THREDDS_S3_RETRY_SLEEP_SECONDS=2


VARS="
    $VARS
    \$THREDDS_S3_BUCKET_NAME
    \$THREDDS_S3_RETRY_ATTEMPTS
    \$THREDDS_S3_RETRY_SLEEP_SECONDS
"
