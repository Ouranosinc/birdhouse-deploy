if ! echo "${BIRDHOUSE_EXTRA_CONF_DIRS}" | grep -q '/s3[[:space:]]*$'; then
  log ERROR 'The mount-thredds-to-s3 component is enabled but the s3 component is not. Please enable the s3 component or disable the mount-thredds-to-s3 component.'
  exit 1
fi

if ! echo "${BIRDHOUSE_EXTRA_CONF_DIRS}" | grep -q '/thredds[[:space:]]*$'; then
  log ERROR 'The mount-thredds-to-s3 component is enabled but the thredds component is not. Please enable the thredds component or disable the mount-thredds-to-s3 component.'
  exit 1
fi
